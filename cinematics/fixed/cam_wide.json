{
  "meta": {
    "id": "cam_wide",
    "name": "固定机位-远景全景",
    "author": "ImmersiveCinematics",
    "version": 3,
    "description": "远距离全景固定摄像机，展示环境全貌。修改 keyframes 中的 x/y/z 即可重新定位。无限时长，可被其他脚本打断。",
    "interruptible": true,
    "skippable": true,
    "hold_at_end": true,
    "hide_hud": true,
    "hide_arm": true
  },
  "timeline": {
    "total_duration": -1,
    "tracks": [
      {
        "type": "CAMERA",
        "clips": [
          {
            "start_time": 0.0,
            "duration": -1,
            "transition": "cut",
            "interpolation": "linear",
            "interpolation_scope": "clip",
            "position_mode": "absolute",
            "loop": false,
            "keyframes": [
              {
                "time": 0.0,
                "position": { "x": 100, "y": 72, "z": -80 },
                "yaw": 0,
                "pitch": 25,
                "roll": 0,
                "fov": 90,
                "zoom": 1.0,
                "dof": 0
              }
            ]
          }
        ]
      }
    ]
  }
}
