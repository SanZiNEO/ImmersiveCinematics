            "start_time": 0.0,
            "duration": -1,
            "transition": "cut",
            "interpolation": "linear",
            "interpolation_scope": "segment",
            "position_mode": "relative",
            "loop": true,
            "loop_count": -1,
            "keyframes": [
              { "time": 0.0, "position": { "dx": 5, "dy": 3, "dz": -8 }, "yaw": 150, "pitch": 10, "roll": 0, "fov": 60, "zoom": 1.0, "dof": 0 },
              { "time": 3.0, "position": { "dx": -5, "dy": 3, "dz": -8 }, "yaw": -150, "pitch": 10, "roll": 0, "fov": 60, "zoom": 1.0, "dof": 0 }
            ]
          }
        ]
      },
      {
        "type": "LETTERBOX",
        "clips": [
          {
            "start_time": 0.0,
            "duration": -1,
            "enabled": true,
            "aspect_ratio": 2.35,
            "fade_in": 0.5,
            "fade_out": 0.5
          }
        ]
      }
    ]
  }
}
